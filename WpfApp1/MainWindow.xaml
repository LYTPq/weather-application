<Window x:Class="WpfApp1.MainWindow"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Weather" Height="600" Width="1000" Background="Transparent" 
        WindowStyle="SingleBorderWindow" AllowsTransparency="false" FontFamily="Cambria" WindowStartupLocation="CenterScreen">

    <!--for panels with current weather data-->
    <Window.Resources>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>


        <DataTemplate DataType="{x:Type local:DailyForecastData}">
            <Border CornerRadius="10" Width="85" Padding="10" Margin="4" BorderThickness="1" Background="White" BorderBrush="#e9e9e9" MouseLeftButtonUp="DailyForecast_Click">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding DayOfWeek}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <Image Source="{Binding iconPath}" Width="30" Margin="0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding temp.max, StringFormat={}{0:F0}°}" FontWeight="SemiBold" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding temp.min, StringFormat={}{0:F0}°}" Foreground="gray"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:HourlyForecastData}">
            <Border CornerRadius="10" Width="85" Padding="10" Margin="4" BorderThickness="1" Background="White" BorderBrush="#e9e9e9">
                <StackPanel>
                    <TextBlock Text="{Binding time}"  FontSize="15" HorizontalAlignment="Center" Margin="0,5,0,0" FontWeight="bold"/>
                    <TextBlock Text="{Binding main.temp, StringFormat={}{0:F0}°}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding wind.speed, StringFormat={}{0} km/h}"  HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>







    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2.2*" />
        </Grid.ColumnDefinitions>
           <!--first side of the window-->
        <Border Grid.Column="0" Background="GhostWhite" CornerRadius="0 0 0 0" Padding="5">

            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Top">

                <Border CornerRadius="13" Background="White" BorderBrush="Gray" BorderThickness="1">
                    <xctk:WatermarkTextBox x:Name="search" Background="Transparent" BorderThickness="0" Margin="0,0,0,3" Watermark="Search…" KeyDown="Search_KeyDown"/>
                </Border>

                <StackPanel>
                    <Image Source="{Binding IconPath}" Width="130" Height="130"  HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentWeather.main.temp, StringFormat={}{0:F0}°C}" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentDateTime}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Separator Margin="0,10" Background="LightGray" Height="1"/>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentWeather.weather[0].description, StringFormat='Condition: {0}'}" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentRain, StringFormat='Rain: {0} mm'}" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10" FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentWeather.name, StringFormat='City: {0}'}" FontSize="16" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,60,0,10" FontWeight="Bold"/>
                </StackPanel>

            </StackPanel>
        </Border>
        
         <!--secon side of the window-->
        <Border Grid.Column="1" Background="WhiteSmoke" CornerRadius="0 0 0 0" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1.3*"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Rows="2">
                    
                    <ItemsControl ItemsSource="{Binding DailyForecast}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding HourlyForecast}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>



                </UniformGrid>

                <!--data about current temp-->
                <UniformGrid Rows="2" Columns="3" Margin="0,0,0,0" Grid.Row="1">

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Min/Max Temperature" FontWeight="bold" Margin="0,0,0,4" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentWeather.main.temp_min, StringFormat='{}Min {0:F0}°C'}" FontSize="20" HorizontalAlignment="Left" Margin="0,10,0,0" FontWeight="bold" />
                            <TextBlock Text="{Binding CurrentWeather.main.temp_max, StringFormat='{}Max {0:F0}°C'}" FontSize="20" HorizontalAlignment="Left" Margin="0,15,0,0" FontWeight="bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Wind" FontWeight="Bold" Margin="0,0,0,4" Foreground="Gray" />
                            <TextBlock Text="{Binding CurrentWeather.wind.speed, StringFormat={}{0} km/h}" FontSize="20" HorizontalAlignment="left" Margin="0,10,0,0" FontWeight="bold"/>
                            <TextBlock Text="{Binding WindDirection, StringFormat='Direction: {0}'}" FontSize="20" HorizontalAlignment="left" Margin="0,15,0,0" FontWeight="bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Sunrise Sunset" FontWeight="Bold" Margin="0,0,0,4" Foreground="Gray"/>
                            <TextBlock Text="{Binding Sunrise}" FontSize="20" HorizontalAlignment="Left" Margin="0,10,0,0" FontWeight="bold"/>
                            <TextBlock Text="{Binding Sunset}" FontSize="20" HorizontalAlignment="Left" Margin="0,15,0,0" FontWeight="bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Humidity" FontWeight="Bold" Margin="0,0,0,4" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentWeather.main.humidity, StringFormat={}{0} %}" FontSize="20" HorizontalAlignment="Left" Margin="0,10,0,0" FontWeight="bold"/>
                            <TextBlock Text="{Binding HumidityCategory}" FontSize="20" HorizontalAlignment="Left" Margin="0,10,0,0" FontWeight="bold" />
                        </StackPanel>
                    </Border>


                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Visibility" FontWeight="Bold" Margin="0,0,0,4" Foreground="Gray"/>
                            <TextBlock Text="{Binding Visibility, StringFormat={}{0} km}" FontSize="20" HorizontalAlignment="Left" FontWeight="bold" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding VisibilityCategory}" FontSize="20" HorizontalAlignment="Left" FontWeight="bold" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>


                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Air quality" FontWeight="Bold" Margin="0,0,0,4" Foreground="Gray"/>
                            <TextBlock Text="{Binding Pollution}" FontSize="20" HorizontalAlignment="Left" Margin="0,30,0,0" FontWeight="bold"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Grid>
        </Border>


    </Grid>
</Window>
